@host = http://localhost:5140

### Health
GET {{host}}/health

### Registrar usuario
POST {{host}}/auth/registro
Content-Type: application/json

{
  "nombre": "Ana",
  "email": "ana@example.com",
  "contrasena": "secreto123"
}

### Login
# @name login
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "ana@example.com",
  "contrasena": "secreto123"
}

> {% client.global.set("token", response.body.tokenAcceso); %}

### Crear transaccion
# @name crearTransaccion
POST {{host}}/transacciones
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "monto": 25.50,
  "descripcion": "Almuerzo",
  "categoria": "Comida",
  "fecha": "2026-07-14",
  "tipo": "Gasto"
}

> {% client.global.set("transaccionId", response.body.id); %}

### Listar transacciones
GET {{host}}/transacciones
Authorization: Bearer {{token}}

### Obtener transaccion
GET {{host}}/transacciones/{{transaccionId}}
Authorization: Bearer {{token}}

### Actualizar transaccion
PUT {{host}}/transacciones/{{transaccionId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "monto": 30,
  "descripcion": "Almuerzo actualizado"
}

### Resumen de presupuesto
GET {{host}}/presupuesto/resumen
Authorization: Bearer {{token}}

### Eliminar transaccion
DELETE {{host}}/transacciones/{{transaccionId}}
Authorization: Bearer {{token}}
